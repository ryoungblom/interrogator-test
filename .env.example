# Copy this file to `.env` and fill in real values.
# Then load it into your shell with:
#   export $(grep -v '^#' .env | xargs)
# or use direnv / dotenv / whatever your editor reads.

# Required: OpenAI API key. The OpenAI Agents SDK picks this up from the
# environment automatically. Do not commit your real key.
OPENAI_API_KEY=sk-replace-me

# Optional: override the default models used by the agents.
# DEFAULT_MODEL=gpt-4o-mini
# DEFAULT_INTERROGATOR_MODEL=gpt-4o-mini
